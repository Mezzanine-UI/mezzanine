{
  "name": "mezzanine",
  "version": "0.0.0",
  "description": "mezzanine ui",
  "repository": "git@github.com:Mezzanine-UI/mezzanine.git",
  "author": "Mezzanine",
  "contributors": [
    "Jay Chen <gcobs135102@gmail.com>",
    "Travor Lee <travor20814@gmail.com>"
  ],
  "license": "MIT",
  "keywords": [
    "mezzanine",
    "ui",
    "angular",
    "react"
  ],
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/icons",
    "packages/ng",
    "packages/react",
    "packages/system"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "check": "./scripts/check.sh",
    "check:lint": "./scripts/check.sh --lint-only",
    "check:types": "./scripts/check.sh --types-only",
    "format": "prettier './**/*.{json,md,mdx,html}' --write",
    "lint:css": "stylelint ./**/*.scss",
    "lint:es": "eslint . --ext .js,.ts,.tsx,.mdx,.html",
    "lint": "yarn lint:es && yarn lint:css",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test:coverage",
    "build": "nx run-many -t build",
    "build:clean": "nx run-many -t build:clean",
    "build:affected": "nx affected -t build",
    "test:affected": "nx affected -t test",
    "graph": "nx graph",
    "release": "lerna version && yarn build && lerna publish from-package",
    "release:canary": "lerna version prerelease --preid canary --no-push && yarn build && lerna publish from-package --dist-tag canary --yes",
    "release:alpha": "lerna version prerelease --preid alpha --no-push && yarn build && lerna publish from-package --dist-tag alpha --yes",
    "release:beta": "lerna version prerelease --preid beta --no-push && yarn build && lerna publish from-package --dist-tag beta --yes",
    "release:rc": "lerna version prerelease --preid rc --no-push && yarn build && lerna publish from-package --dist-tag rc --yes",
    "release:stable": "lerna version --no-push && yarn build && lerna publish from-package --dist-tag latest --yes",
    "version:canary": "lerna version --no-push --no-git-tag-version --preid canary",
    "version:alpha": "lerna version prerelease --no-push --preid alpha",
    "version:beta": "lerna version prerelease --no-push --preid beta",
    "version:rc": "lerna version prerelease --no-push --preid rc",
    "version:stable": "lerna version --no-push",
    "commit": "git-cz",
    "system:test": "nx run @mezzanine-ui/system:test",
    "system:test:coverage": "nx run @mezzanine-ui/system:test:coverage",
    "core:test": "nx run @mezzanine-ui/core:test",
    "core:test:coverage": "nx run @mezzanine-ui/core:test:coverage",
    "react:test": "nx run @mezzanine-ui/react:test",
    "react:test:coverage": "nx run @mezzanine-ui/react:test:coverage",
    "ng:test": "nx run @mezzanine-ui/ng:test",
    "ng:test:coverage": "nx run @mezzanine-ui/ng:test:coverage",
    "ng:storybook": "ng run ng-storybook:storybook",
    "ng:build-storybook": "ng run ng-storybook:build-storybook",
    "react:build": "nx run @mezzanine-ui/react:build-storybook",
    "react:storybook": "nx run @mezzanine-ui/react:storybook",
    "hub:storybook": "storybook dev -c .storybook-hub -p 6008",
    "hub:build-storybook": "storybook build -c .storybook-hub -o storybook-hub-static",
    "storybook:build-composed": "yarn react:build && yarn ng:build-storybook && yarn hub:build-storybook && node scripts/compose-storybooks.mjs",
    "parity": "tsx tools/parity/compare.ts",
    "parity:all": "tsx tools/parity/compare.ts --all",
    "parity:lint-ng-content": "node tools/parity/check-ng-content-selectors.mjs",
    "parity:check-tokens": "node tools/parity/check-hardcoded-tokens.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.6",
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular-devkit/core": "^21.2.6",
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.4",
    "@angular/cli": "^21.2.6",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/compat": "^1.2.8",
    "@eslint/js": "^9.38.0",
    "@nx/js": "^21.6.5",
    "@rollup/plugin-typescript": "^12.1.2",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/angular": "^9.1.20",
    "@storybook/react-webpack5": "^9.1.20",
    "@testing-library/angular": "^17.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react-refresh": "^0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "babel-loader": "^10.0.0",
    "commitizen": "^4.3.1",
    "css-loader": "^7.1.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.38.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-storybook": "^9.1.20",
    "fs-extra": "^11.3.2",
    "glob": "^11.0.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.1.2",
    "lerna": "^8.2.4",
    "lint-staged": "^15.5.1",
    "ng-packagr": "^21.2.2",
    "nx": "21.6.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resolve-url-loader": "^5.0.0",
    "rollup": "^4.52.5",
    "rxjs": "^7.8.2",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.5",
    "storybook": "^9.1.20",
    "style-loader": "^4.0.0",
    "stylelint": "^16.18.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.11.1",
    "ts-jest": "29.4.5",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "webpack": "^5.102.1",
    "zone.js": "~0.16.1"
  },
  "packageManager": "yarn@4.10.3"
}
