{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "rootDir": "../..",
    "types": ["jest"],
    "paths": {
      "@mezzanine-ui/icons": ["../icons/src"],
      "@mezzanine-ui/system/*": ["../system/src/*"],
      "@mezzanine-ui/core/*": ["../core/src/*"],
      "@angular/core/testing": [
        "../../node_modules/@angular/core/types/testing.d.ts"
      ],
      "@angular/core": ["../../node_modules/@angular/core/types/core.d.ts"],
      "@angular/platform-browser-dynamic/testing": [
        "../../node_modules/@angular/platform-browser-dynamic/types/testing.d.ts"
      ],
      "@mezzanine-ui/ng/*": ["./*"]
    }
  },
  "include": [
    "src",
    "button",
    "icon",
    "utils",
    "services",
    "transition",
    "portal",
    "popper",
    "_internal",
    "typography",
    "separator",
    "spin",
    "badge",
    "tag",
    "empty",
    "backdrop",
    "tooltip",
    "overflow-tooltip",
    "description",
    "notifier",
    "message",
    "alert-banner",
    "skeleton",
    "progress",
    "result-state",
    "anchor",
    "floating-button",
    "clear-actions",
    "checkbox",
    "radio",
    "toggle",
    "selection-card",
    "tab",
    "slider",
    "inline-message",
    "form",
    "text-field",
    "input",
    "textarea",
    "modal",
    "drawer",
    "popconfirm",
    "pagination",
    "scrollbar",
    "dropdown",
    "select",
    "autocomplete",
    "navigation",
    "breadcrumb",
    "stepper",
    "accordion",
    "card",
    "calendar",
    "time-panel",
    "picker",
    "date-picker",
    "time-picker",
    "multiple-date-picker",
    "date-range-picker",
    "date-time-picker",
    "date-time-range-picker",
    "time-range-picker",
    "page-footer",
    "content-header",
    "page-header",
    "section",
    "filter-area",
    "layout",
    "upload",
    "cascader",
    "cropper",
    "notification-center",
    "table"
  ]
}
